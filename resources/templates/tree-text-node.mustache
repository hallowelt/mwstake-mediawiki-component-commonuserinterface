<li{{#id}} id="{{.}}"{{/id}} class="mws-tree-item{{class}}">
	<div>
		{{#expandBtn}}<a class="mws-tree-expander{{class}}" role="button" tabindex="0" aria-label="{{text}}"{{#id}} aria-controls="{{.}}-children"{{/id}}{{#hasChildren}} aria-expanded="{{expanded}}"{{/hasChildren}}></a>{{/expandBtn}}<span id="{{labelId}}" class="mws-tree-item-label{{#isNew}} new{{/isNew}}" tabindex="0">{{{preHtml}}}{{text}}</span>
	</div>
	{{#hasChildren}}
	<ul {{#id}} id="{{.}}-children"{{/id}} class="mws-tree mws-tree-item-children{{#expanded}} show{{/expanded}}" role="group" aria-labelledby="{{labelId}}">
		{{#children}}{{{.}}}{{/children}}
	</ul>
	{{/hasChildren}}
</li>